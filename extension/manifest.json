{
  "manifest_version": 3,
  "name": "CivicOS AI — Telangana ePASS Assistant",
  "version": "2.1.0",
  "description": "An AI copilot that guides students step-by-step through the Telangana ePASS scholarship portal by highlighting exactly what to click next.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://telanganaepass.cgg.gov.in/*",
    "https://tgepass.cgg.gov.in/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://telanganaepass.cgg.gov.in/*",
        "https://tgepass.cgg.gov.in/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "overlay/overlay.js",
        "overlay/overlay.css"
      ],
      "matches": [
        "https://telanganaepass.cgg.gov.in/*",
        "https://tgepass.cgg.gov.in/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ]
    }
  ]
}
